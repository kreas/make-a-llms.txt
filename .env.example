# Turso
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Auth (run `openssl rand -base64 32 | pbcopy` in your console to copy a secure key to your clipboard)
SESSION_SECRET=

# Resend (leave blank in dev to log OTPs to the console)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Vercel Blob (copy from your Vercel project's Storage tab)
BLOB_READ_WRITE_TOKEN=

# Base URL for email links (set to your production domain in deployed environments)
PUBLIC_BASE_URL=http://localhost:3000

# Cron (run `openssl rand -base64 32` to generate a secure secret)
CRON_SECRET=

# Cloudflare Browser Rendering (per-page markdown)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
# Optional tuning
CLOUDFLARE_BR_CONCURRENCY=5
PAGES_PER_RUN_CAP=250

# AI Gateway (for page summary generation)
AI_GATEWAY_API_KEY=
# Optional tuning
AI_SUMMARY_CONCURRENCY=15
AI_SUMMARY_MAX_INPUT_BYTES=200000
