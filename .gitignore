# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# worktrees
.worktrees/
.claude/worktrees/

# claire local state
.claire/

# vercel
.vercel

# local libsql/sqlite database files
local.db*

# typescript
*.tsbuildinfo
next-env.d.ts
.env*.local

# Generated OpenAPI document (rebuilt by pnpm build:openapi)
public/openapi.json

# fumadocs-mdx generated source files (rebuilt by next dev/build)
/.source/

# Local scratch / experiments
scratch/
